DATA_ROOT=../service_data/dockge

# Directory where Dockge stores and manages compose stacks.
#
# IMPORTANT: Dockge runs `docker compose` commands using the HOST path, so the
# path must be identical inside and outside the container. This means:
#   - Must be an absolute path (no relative paths like ../data/stacks)
#   - The same value is used on both sides of the volume mount
#   - Create the directory before starting: mkdir -p <this path>
#
# Use a path already shared with Docker (e.g. under /mnt/docker-data).
DOCKGE_STACKS_DIR=/opt/homeserver/stacks
