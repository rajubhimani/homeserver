# Immich — Storage paths
UPLOAD_LOCATION=../service_data/immich/upload
DB_DATA_LOCATION=../service_data/immich/postgres

# Media library paths (read-only mounts from your media drive)
PHOTOS_LOCATION=/mnt/seagate/Photos
VIDEOS_LOCATION=/mnt/seagate/Videos

# Immich secret (generate with: openssl rand -hex 32)
IMMICH_SECRET=your_hex_secret_here

# Postgres
DB_USERNAME=immich
DB_PASSWORD=your_strong_password
DB_DATABASE_NAME=immich

# DB_URL must use the service name (immich-database), not localhost
DB_URL=postgresql://immich:your_strong_password@immich-database:5432/immich

# Offline remover API key (create in Immich → Account → API Keys)
IMMICH_OFFLINE_API_KEY=your_api_key_here
