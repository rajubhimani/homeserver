# Vaultwarden — Storage paths
DATA_ROOT=../service_data/vaultwarden

# Your domain (used for HTTPS/cookies)
VAULTWARDEN_DOMAIN=https://vault.yourdomain.com

# Admin token (generate with: openssl rand -base64 48)
ADMIN_TOKEN=your_admin_token_here

# Registration — set to false to disable, true to allow
SIGNUPS_ALLOWED=false
