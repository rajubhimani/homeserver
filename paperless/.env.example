# Paperless-ngx — Storage paths
DATA_ROOT=/mnt/docker-data/homeserver/test/data

# Timezone
TZ=Asia/Kolkata

# Postgres
POSTGRES_DB=paperless
POSTGRES_USER=paperless
POSTGRES_PASSWORD=your_strong_password

# Secret key (generate with: openssl rand -hex 32)
PAPERLESS_SECRET_KEY=your_hex_secret_here

# URL paperless is served at
PAPERLESS_URL=http://192.168.1.100:8010

# Admin account (created on first start)
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=your_strong_password
