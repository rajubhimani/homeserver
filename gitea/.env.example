# Gitea — Storage paths
DATA_ROOT=../service_data/gitea

# Postgres
POSTGRES_DB=gitea
POSTGRES_USER=gitea
POSTGRES_PASSWORD=your_strong_password

# Domain and root URL
GITEA_DOMAIN=git.yourdomain.com
GITEA_ROOT_URL=https://git.yourdomain.com

# Registration — set to true to disable, false to allow
DISABLE_REGISTRATION=true
