# Nextcloud — Storage paths
DATA_ROOT=../service_data/nextcloud
USER_DATA_ROOT=/mnt/seagate

# Postgres
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=your_strong_password

# Nextcloud admin account
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=your_strong_password

# Space-separated list: add your server IP and Tailscale domain
NEXTCLOUD_TRUSTED_DOMAINS=localhost 192.168.1.100 *.ts.net
