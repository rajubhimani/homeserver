DATA_ROOT=../service_data/wg-easy

# Public hostname or IP of your server — what clients connect to (required)
WG_HOST=your.server.ip.or.domain

# Admin password hash — generate with:
#   docker run --rm -it ghcr.io/wg-easy/wg-easy wgpw YOUR_PASSWORD
WG_PASSWORD_HASH=

# WireGuard UDP port — must be open in firewall
WG_PORT=51820

# DNS pushed to clients (1.1.1.1 = Cloudflare, 8.8.8.8 = Google)
WG_DEFAULT_DNS=1.1.1.1

# Client IP subnet — x is replaced with the client's assigned number
WG_DEFAULT_ADDRESS=10.8.0.x

# What traffic routes through the VPN:
#   Full tunnel (all traffic):         0.0.0.0/0,::/0
#   Split tunnel (LAN resources only): 192.168.1.0/24
#   Split tunnel (multiple ranges):    10.0.0.0/8,192.168.0.0/16
WG_ALLOWED_IPS=0.0.0.0/0,::/0

# MTU — 1420 works for most setups; lower to 1280 if clients have issues
WG_MTU=1420

# Keep connections alive through NAT (seconds)
WG_PERSISTENT_KEEPALIVE=25

# Web UI language
WG_LANG=en
