# ── Global homeserver configuration ──────────────────────────────────────────
# Set your domain here — homeserver.sh injects it into all services that need it.
DOMAIN=yourdomain.com

# ── Container runtime ─────────────────────────────────────────────────────────
# Set to 'podman' to use Podman instead of Docker.
RUNTIME=docker

# ── Docker/Podman socket ──────────────────────────────────────────────────────
# Docker:  /var/run/docker.sock
# Podman (rootful):  /run/podman/podman.sock
# Podman (rootless): /run/user/1000/podman/podman.sock  (replace 1000 with your UID)
DOCKER_SOCKET=/var/run/docker.sock
