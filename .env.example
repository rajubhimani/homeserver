# ── Global homeserver configuration ──────────────────────────────────────────
# Set your domain here — homeserver.sh injects it into all services that need it.
DOMAIN=yourdomain.com

# ── Container runtime ────────────────────────────────────────────────────────
# Uncomment ONE group below. Comment out the other.

# ── Docker (default) ──
RUNTIME=docker
DOCKER_SOCKET=/var/run/docker.sock

# ── Podman (rootful) ──
# RUNTIME=podman
# DOCKER_SOCKET=/run/podman/podman.sock

# ── Podman (rootless — replace 1000 with your UID) ──
# RUNTIME=podman
# DOCKER_SOCKET=/run/user/1000/podman/podman.sock
